# Nest LLM 게이트웨이 (chocolat:7780, Tailscale magic DNS hostname 사용 — IP 변동 무관)
NEST_BASE_URL=http://chocolat.tail575fea.ts.net:7780
NEST_TOKEN=YOUR_TOKEN_HERE

# MongoDB
MONGO_URL=mongodb://localhost:27017
MONGO_DB=oracle

# 정본 vault 경로
VAULT_DIR=/Users/astonlee/projects/oracle/corpus

# Task → Nest alias override (비우면 Nest enabled 첫 모델 자동 선택 — 동적)
#
# 쿠키(빠른 1차 반응) — 캡처마다 베르 전에 짧은 첫인상 한마디. 코멘트 품질을
# 올리려면 좋은 모델을 둔다.
# ORACLE_QUICK=gemini           # 한마디 — 텍스트·사진
# ORACLE_QUICK_AV=gemini-flash  # 한마디 — 영상·음성(멀티모달)
#
# ORACLE_VLM=claude
# ORACLE_INSIGHT=claude
# ORACLE_DIGEST=claude
# ORACLE_WEEKLY=claude
# ORACLE_MONTHLY=claude
# ORACLE_TYPE=claude
# ORACLE_THREAD=claude
# ORACLE_QUERY=claude
# ORACLE_CHAT=claude            # 대화 모드 (비우면 query → 첫 모델 순 fallback)

# 검색 임베딩 — Nest에 등록한 embed alias (openai|openai_compat, /api/embed 지원).
# 비우면 임베딩 비활성 → 3요소 검색 잠자고 최근순 fallback. venv에 numpy 필요.
# ORACLE_EMBED=embed
# 직결 우회(임시): 라이브 Nest에 /api/embed 미배포 동안 로컬 임베딩 서버로 직접.
# Nest 갱신 후 이 줄을 지우면 Nest 경유로 복귀.
# ORACLE_EMBED_URL=http://127.0.0.1:7790/v1/embeddings

# 소리(오디오) 인식 — 오디오 입력 가능 모델 alias (예: gemini). 비우면 저장만.
# ORACLE_AUDIO=gemini

# 메모리 튜닝 (디폴트 그대로 써도 됨)
# ORACLE_WORKING_DAYS=30        # 즉답에 주입할 워킹메모리 일수 (0=비활성)
# ORACLE_WORKING_MAX_CHARS=12000  # 워킹메모리 문자 상한 (최신 우선, 0=무제한)
# ORACLE_MEM_W_SIM=1.0          # 검색 3요소 가중치 (유사도/최근성/중요도)
# ORACLE_MEM_W_RECENCY=1.0
# ORACLE_MEM_W_IMPORTANCE=1.0
# ORACLE_MEM_TAU_DAYS=30        # 최근성 지수감쇠 시정수

# API 토큰 (opt-in 인증) — 설정하면 loopback 외 모든 요청에 X-Oracle-Token 요구.
# 폰 앱도 같은 값으로 빌드해야 함: flutter build apk --dart-define=ORACLE_TOKEN=...
# ORACLE_TOKEN=

# ── Tesla Fleet API (차량 위치·운행 → 차 상태머신 보강) ──────────
# developer.tesla.com 앱 생성 후 발급. 비우면 비활성(authed=False, graceful). 절차=docs/tesla-setup.md
# TESLA_CLIENT_ID=
# TESLA_CLIENT_SECRET=
# 아래는 config.py에 기본값 있음 — 바꿀 때만:
# TESLA_DOMAIN=oraclecar.pages.dev
# TESLA_REDIRECT_URI=http://localhost:8080/callback
# TESLA_API_BASE=https://fleet-api.prd.na.vn.cloud.tesla.com   # 한국=NA. EU/중국이면 교체
# TESLA_SCOPES=openid offline_access vehicle_device_data vehicle_location vehicle_charging_cmds
